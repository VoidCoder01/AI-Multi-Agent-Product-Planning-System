# Copy to .env and fill in values. Never commit .env.
# Use one provider key:
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Model resolution order: OPENAI_MODEL -> OPENROUTER_MODEL
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_MODEL=google/gemma-2-9b-it:free
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SEC=120
TASK_AGENT_MAX_WORKERS=3
REDIS_URL=                  # optional: redis://localhost:6379/0

# Optional: audio transcription via Whisper (used for .mp3/.wav/.m4a/.webm uploads)
WHISPER_MODEL=whisper-1
WHISPER_TIMEOUT_SEC=120
