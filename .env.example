# Copy to .env and fill in values. Never commit .env.

# Required — Anthropic API key for all agents
ANTHROPIC_API_KEY=

# Optional — defaults match previous hardcoded behavior
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_TIMEOUT_SEC=300

# Retries after the first failed LLM call (total attempts = LLM_MAX_RETRIES + 1)
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_BASE_SEC=0.6

# Audit log truncation (characters stored per request/response in JSONL)
AGENT_LOG_INPUT_MAX_CHARS=6000
AGENT_LOG_OUTPUT_MAX_CHARS=6000

# Parallel epic workers in TaskAgent (capped by number of epics)
TASK_AGENT_MAX_WORKERS=10
