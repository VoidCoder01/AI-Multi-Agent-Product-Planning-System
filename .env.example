# Copy to .env and fill in values. Never commit .env.
# Claude-first provider routing for enterprise setup:
# anthropic | openrouter | openai | auto
LLM_PROVIDER=anthropic
LLM_PROVIDER_TOGGLE_ENABLED=false

# Provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Provider models
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SEC=120
TASK_AGENT_MAX_WORKERS=3
REDIS_URL=                  # optional: redis://localhost:6379/0

# Optional: audio transcription via Whisper (used for .mp3/.wav/.m4a/.webm uploads)
WHISPER_MODEL=whisper-1
WHISPER_TIMEOUT_SEC=120

# API security/CORS hardening
# Auth mode selection:
# - JWT mode (preferred): set JWT_SECRET (+ optional JWT_ISSUER/JWT_AUDIENCE)
# - Static token mode (legacy fallback): set API_BEARER_TOKEN
# - If neither is set, API auth is disabled (local dev only)
#
# JWT role claims supported:
# - roles: ["planner:read", "planner:generate", "planner:readwrite", "admin"]
# - scope: "planner:read planner:generate"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
# Force-disable all API auth checks (dev/trusted env only)
AUTH_DISABLED=false
AUTH_MODE_TOGGLE_ENABLED=false

# Frontend auth toggle visibility (read at frontend build time)
VITE_SHOW_AUTH_TOGGLE=false
VITE_SHOW_LLM_PROVIDER_SELECTOR=true

# Legacy fallback token mode
# If API_BEARER_TOKEN is set, all /api/* routes except /api/health require:
# Authorization: Bearer <token>
API_BEARER_TOKEN=
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Session persistence backend
# - file (default): local JSON files
# - postgres: set SESSION_STORE_BACKEND=postgres and DATABASE_URL
SESSION_STORE_BACKEND=file
DATABASE_URL=

# LangGraph checkpointing (step-level durable state)
# memory | sqlite | postgres (postgres uses DATABASE_URL)
LANGGRAPH_CHECKPOINTER=memory
LANGGRAPH_SQLITE_PATH=data/langgraph_checkpoints.sqlite

# Upload/session safety limits
MAX_UPLOAD_BYTES=10485760
MAX_DOCUMENT_CHARS=250000
MAX_SESSION_INDEX_ITEMS=4000
